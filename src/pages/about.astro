---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead
			title={`关于我 | ${SITE_TITLE}`}
			description="了解我的学习方向、技术栈和项目经历。"
		/>
	</head>

	<body>
		<Header />

		<main>
			<h1>关于我</h1>

			<p>
				你好，我是 D4Y0，一名计算机专业学生。
			</p>

			<p>
				目前主要学习人工智能、计算机视觉、OpenCV、
				YOLO 目标检测、C/C++、Linux 和 Web 开发。
			</p>

			<h2>目前正在做的事情</h2>

			<ul>
				<li>搭建个人技术博客</li>
				<li>完成计算机视觉相关项目</li>
				<li>整理项目代码并上传到 GitHub</li>
				<li>学习现代 Web 开发技术</li>
			</ul>

			<h2>GitHub</h2>

			<p>
				<a
					href="https://github.com/lpossji"
					target="_blank"
					rel="noopener noreferrer"
				>
					访问我的 GitHub
				</a>
			</p>
		</main>

		<Footer />
	</body>
</html>
